<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="336.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.AddGradeController">

    <children>
        <Label layoutX="120.0" layoutY="120.0" text="Add Grade" />
        <ComboBox fx:id="gradeTypeBox" layoutX="93.0" layoutY="190.0" prefWidth="150.0" promptText="Select grade type" />
        <TextField fx:id="scoreField" layoutX="93.0" layoutY="250.0" prefWidth="150.0" promptText="Enter score" />
        <Button layoutX="250.0" layoutY="80.0" text="Done" onAction="#addGradeAndReturn" />
        <Button layoutX="40.0" layoutY="80.0" text="←" onAction="#goBackToGrades" />
    </children>
</AnchorPane>